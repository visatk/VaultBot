{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "dev",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vault",
      "database_id": "37e7399d-c819-4478-8006-a74aea147b4b"
    }
  ],
   "kv_namespaces": [
    {
      "binding": "KV",
      "id": "aba08ec739114c07bf4bf4cfcdfdee05"
    }
  ]
}
