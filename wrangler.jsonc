{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "dev",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cybercoderbd",
      "database_id": "42b9b4fc-c442-40be-8b89-df0cca15a0c6"
    }
  ],
   "kv_namespaces": [
    {
      "binding": "KV",
      "id": "bf117b44d5374d77a67c1ad5678075cc"
    }
  ]
}
